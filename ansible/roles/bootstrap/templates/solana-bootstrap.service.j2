# {{ ansible_managed }}
[Unit]
Description=Solana Bootstrap Validator
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=solana
Group=solana
ExecStart=/usr/local/bin/solana-validator \
  --identity {{ keypair_path }}/identity.json \
  --vote-account {{ keypair_path }}/vote-account.json \
  --ledger {{ ledger_path }} \
  --rpc-port {{ rpc_port }} \
  --gossip-port {{ gossip_port }} \
  --dynamic-port-range 8000-8020 \
  --limit-ledger-size 50000000 \
  --log {{ log_path }}/validator.log \
  --metrics-port {{ metrics_port }} \
  --gossip-host {{ ansible_host }} \
  --no-port-check \
  --rpc-faucet-address {{ hostvars[groups['faucet'][0]]['private_ip'] }}:9900 \
  --no-wait-for-vote-to-start-leader \
  --enable-rpc-transaction-history
Restart=always
RestartSec=10
LimitNOFILE=1000000
LimitNPROC=65535
TimeoutStopSec=60
Environment="PATH=/usr/local/bin:/usr/bin:/bin"

[Install]
WantedBy=multi-user.target
